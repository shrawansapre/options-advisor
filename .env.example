# Copy this to .env and fill in your key
# Get your key from https://console.anthropic.com

# ── Local dev only (npm run dev) ──────────────────────────────────────────────
# Enables direct browser → Anthropic calls. Remove this in production.
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Server-side (vercel dev / production) ─────────────────────────────────────
# Set this as an Environment Variable in your Vercel project dashboard.
# When VITE_ANTHROPIC_API_KEY is absent, the app routes through /api/analyze.
ANTHROPIC_API_KEY=sk-ant-api03-...
